# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your-strong-password-here
DB_DATABASE=online_shop

# JWT 密钥（请生成强随机密钥）
JWT_SECRET=your-jwt-secret-key-here
ADMIN_JWT_SECRET=your-admin-jwt-secret-key-here

# 内部调用密钥（用于定时任务等内部接口）
ADMIN_INTERNAL_KEY=your-internal-key-here

# 接码平台 Token（ejiema.com）
MAAPI_TOKEN=your-maapi-token-here

# 支付宝配置
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key

# 服务器配置
PORT=5100
NODE_ENV=development
LOG_LEVEL=info

# CORS 允许的来源（生产环境配置，多个用逗号分隔）
# ALLOWED_ORIGINS=http://localhost:5100,https://yourdomain.com

# 支付宝回调URL（生产环境需要配置公网地址）
ALIPAY_NOTIFY_URL=http://localhost:5100/api/payment/notify
